#include <stdio.h>

int main(){
    int n, bt[10], rt[10], tq;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++){
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d",&tq);

    int done, time=0;

    do{
        done=1;
        for(int i=0;i<n;i++){
            if(rt[i]>0){
                done=0;
                if(rt[i]>tq){
                    time+=tq;
                    rt[i]-=tq;
                } else{
                    time+=rt[i];
                    rt[i]=0;
                }
            }
        }
    }while(!done);

    printf("Round Robin Completed\n");
    return 0;
}
